#!/usr/bin/env bash
set +euo pipefail

checkout="${BUILDKITE_BUILD_CHECKOUT_PATH:-$PWD}"
deps_dir="$checkout/deps"
mkdir -p "$deps_dir" >/dev/null 2>&1 || true

upload_if_present() {
  local p="$1"
  if [[ -n "$p" && -f "$p" ]]; then
    if command -v buildkite-agent >/dev/null 2>&1; then
      buildkite-agent artifact upload "$p" >/dev/null 2>&1 || true
    fi
  fi
}

# Always try to upload cuNumeric build logs (these live in the checkout)
upload_if_present "$deps_dir/build.log"
for f in "$deps_dir"/*.log "$deps_dir"/*.err; do
  [[ -f "$f" ]] && upload_if_present "$f"
done

# Try to find Legate's build.log and copy it into the checkout so it can be uploaded.
legate_log=""

# 1) Best-effort: derive it from Legate.LEGATE_LIBDIR (often inside a scratchspace)
if command -v julia >/dev/null 2>&1; then
  legate_libdir="$(julia --project -e 'try; using Legate; println(Legate.LEGATE_LIBDIR); catch; end' 2>/dev/null | tail -n 1)"
  if [[ -n "${legate_libdir:-}" && -d "${legate_libdir:-}" ]]; then
    for cand in \
      "$(dirname "$legate_libdir")/build.log" \
      "$(dirname "$legate_libdir")/../build.log" \
      "$(dirname "$legate_libdir")/../../build.log"
    do
      if [[ -f "$cand" ]]; then
        legate_log="$cand"
        break
      fi
    done
  fi
fi

# 2) Fallback: search depots for Legate scratchspace build.log
if [[ -z "$legate_log" ]]; then
  depots="${JULIA_DEPOT_PATH:-}"
  IFS=':' read -r -a depot_arr <<<"$depots"
  # If JULIA_DEPOT_PATH isn't set, try default locations used by the julia-buildkite-plugin
  if [[ "${#depot_arr[@]}" -eq 0 ]]; then
    depot_arr=("$HOME/.cache/julia-buildkite-plugin/depots" "$HOME/.julia")
  fi

  # Legate.jl UUID (used in scratchspaces path)
  legate_uuid="44cfe95a-1eb2-52ea-b672-e2afdf69b78f"

  for depot in "${depot_arr[@]}"; do
    [[ -d "$depot" ]] || continue

    # Handle both direct depots and the plugin's "depots/<uuid>/" layout
    search_roots=("$depot")
    if [[ "$(basename "$depot")" == "depots" ]]; then
      for sub in "$depot"/*; do
        [[ -d "$sub" ]] && search_roots+=("$sub")
      done
    fi

    for root in "${search_roots[@]}"; do
      cand="$(find "$root/scratchspaces/$legate_uuid" -maxdepth 3 -type f -name build.log 2>/dev/null | head -n 1)"
      if [[ -n "$cand" && -f "$cand" ]]; then
        legate_log="$cand"
        break 2
      fi
    done
  done
fi

if [[ -n "$legate_log" && -f "$legate_log" ]]; then
  cp -f "$legate_log" "$deps_dir/legate-build.log" >/dev/null 2>&1 || true
  upload_if_present "$deps_dir/legate-build.log"
fi

exit 0
